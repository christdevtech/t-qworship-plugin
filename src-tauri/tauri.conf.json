{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "t-qworship-plugin",
  "version": "0.1.0",
  "identifier": "com.user.t-qworship-plugin",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "t-qworship-plugin",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "resources/Processing.NDI.Lib.x64.dll"
    ]
  }
}
